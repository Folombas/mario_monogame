#----------------------------- Global Properties ----------------------------#

/outputDir:bin/$(Platform)
/intermediateDir:obj/$(Platform)
/platform:DesktopGL
/config:
/profile:Reach
/compress:False

#-------------------------------- References --------------------------------#


#---------------------------------- Content ---------------------------------#

# Fonts
/importer:FontDescriptionImporter
/processor:FontDescriptionProcessor
/processorParam:PremultiplyAlpha=True
/processorParam:TextureFormat=Compressed
/build:Fonts/Hud.spritefont

# Backgrounds
/importer:TextureImporter
/processor:TextureProcessor
/processorParam:PremultiplyAlpha=True
/processorParam:TextureFormat=Compressed
/build:Sprites/Backgrounds/blue_desert.png
/build:Sprites/Backgrounds/blue_grass.png
/build:Sprites/Backgrounds/blue_land.png
/build:Sprites/Backgrounds/blue_shroom.png
/build:Sprites/Backgrounds/colored_desert.png
/build:Sprites/Backgrounds/colored_grass.png
/build:Sprites/Backgrounds/colored_land.png
/build:Sprites/Backgrounds/colored_shroom.png

